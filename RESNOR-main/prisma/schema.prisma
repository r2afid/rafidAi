generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  role         String   @default("student") // student, teacher
  avatar       String?
  passwordHash String?
  studentId    String?  // e.g. CSE-331
  institution  String?
  phone        String?
  semester     String?
  bio          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  materialProgress  MaterialProgress[]
  quizAttempts      QuizAttempt[]
  chatSessions      ChatSession[]
  streak            Streak?
  earnedBadges      EarnedBadge[]
  notifications     Notification[]
  telemetryRecords  TelemetryRecord[]
  engagementScore   EngagementScore?
  wellbeingCheckins WellbeingCheckin[]
  authSessions       AuthSession[]
  progress           StudentProgress?
  enrollments        Enrollment[]
  misconceptionLogs  MisconceptionLog[]
  cognitiveProfile   CognitiveProfile?
  mistakeExplanations MistakeExplanation[]
  remediationExercises RemediationExercise[]
  followUpMessages   FollowUpMessage[]
  studyNotes         StudyNote[]
  moodEntries        MoodEntry[]
  wellbeingJournals  WellbeingJournal[]
  mentorMessages     MentorMessage[]
  focusSessions      FocusSession[]
  burnoutPredictions BurnoutPrediction[]
  burnoutCheckIns    BurnoutCheckIn[]
  revisionPlans      RevisionPlan[]
  academicRisks      AcademicRisk[]
  companionInteractions CompanionInteraction[]
  voiceInteractions  VoiceInteraction[]
  studyGroupMembers  StudyGroupMember[]
  resources         Resource[]
  wellbeingAnalytics WellbeingAnalytics?
  deathWeekPlans    DeathWeekPlan[]
  teacherAssignments Assignment[]
  topicProgress      TopicProgress[]
  reviews            Review[]
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id            String   @id @default(cuid())
  name          String
  code          String
  description   String?
  teacherId     String
  enrollmentKey String?
  instructor    String?
  category      String   @default("General")
  difficulty    String   @default("Beginner")
  thumbnail     String?
  prerequisites String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  topics      Topic[]
  enrollments Enrollment[]
  assignments Assignment[]
  topicProgress TopicProgress[]
  reviews       Review[]
}

model Enrollment {
  id               String   @id @default(cuid())
  studentId        String
  courseId         String
  attendance       Float    @default(0)
  assignmentMark   Float?
  presentationMark Float?
  midMark          Float?
  finalMark        Float?
  status           String   @default("enrolled")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
}

model TopicProgress {
  id          String   @id @default(cuid())
  studentId   String
  topicId     String
  courseId    String
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  topic   Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, topicId])
}

model Review {
  id        String   @id @default(cuid())
  studentId String
  courseId  String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
}

model Topic {
  id        String   @id @default(cuid())
  name      String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  materials Material[]
  quizzes   Quiz[]
  topicProgress TopicProgress[]
}

model Material {
  id            String   @id @default(cuid())
  title         String
  topicId       String
  contentType   String   @default("document") // document, video, slide
  contentUrl    String?
  estimatedTime Int      @default(30) // minutes
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  topic     Topic              @relation(fields: [topicId], references: [id], onDelete: Cascade)
  progress  MaterialProgress[]
}

model MaterialProgress {
  id               String   @id @default(cuid())
  studentId        String
  materialId       String
  completionStatus String   @default("pending") // pending, in_progress, done
  timeSpent        Int      @default(0) // seconds
  lastAccessedAt   DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  student  User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
}

model Quiz {
  id          String   @id @default(cuid())
  topicId     String
  title       String
  difficulty  String   @default("medium") // easy, medium, hard
  timeLimit   Int      @default(300) // seconds
  teacherId   String?  // non-null = teacher-created quiz
  dueDate     DateTime?
  maxAttempts Int      @default(3)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topic     Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id          String @id @default(cuid())
  quizId      String
  question    String
  optionA     String
  optionB     String
  optionC     String
  optionD     String
  correctKey  String // A, B, C, D
  explanation String?

  quiz    Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]
}

model QuizAttempt {
  id           String   @id @default(cuid())
  studentId    String
  quizId       String
  score        Float    @default(0)
  totalQuestions Int    @default(0)
  correctCount Int      @default(0)
  timeSpent    Int      @default(0) // seconds
  completedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  quiz    Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]
}

model QuizAnswer {
  id              String @id @default(cuid())
  attemptId       String
  questionId      String
  selectedKey     String
  isCorrect       Boolean @default(false)

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id         String   @id @default(cuid())
  studentId  String
  courseId   String?
  title      String?
  mode       String   @default("explain")
  topic      String?
  questionId String?
  context    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student  User         @relation(fields: [studentId], references: [id])
  messages ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // user, assistant
  content   String
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Streak {
  id                 String   @id @default(cuid())
  studentId          String   @unique
  currentStreak      Int      @default(0)
  longestStreak      Int      @default(0)
  lastActiveDate     DateTime @default(now())
  totalActiveDays    Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  student User @relation(fields: [studentId], references: [id])
}

model Badge {
  id            String @id @default(cuid())
  name          String @unique
  description   String
  icon          String // emoji or icon name
  category      String // study, quiz, streak, engagement
  thresholdType String // quiz_score, streak_days, materials_done, engagement_score
  thresholdValue Int
  createdAt     DateTime @default(now())

  earnedBy EarnedBadge[]
}

model EarnedBadge {
  id        String   @id @default(cuid())
  studentId String
  badgeId   String
  earnedAt  DateTime @default(now())

  student User  @relation(fields: [studentId], references: [id])
  badge   Badge @relation(fields: [badgeId], references: [id])

  @@unique([studentId, badgeId])
}

model Notification {
  id          String   @id @default(cuid())
  studentId   String
  title       String
  message     String
  type        String   @default("info") // info, warning, achievement, reminder
  isRead      Boolean  @default(false)
  actionUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student User @relation(fields: [studentId], references: [id])
}

model TelemetryRecord {
  id               String   @id @default(cuid())
  studentId        String
  pageId           String
  activeSeconds    Int      @default(0)
  scrollPercentage Float    @default(0)
  interactionCount Int      @default(0)
  tabFocused       Boolean  @default(true)
  createdAt        DateTime @default(now())

  student User @relation(fields: [studentId], references: [id])
}

model EngagementScore {
  id                    String   @id @default(cuid())
  studentId             String   @unique
  overallScore          Float    @default(0)
  studyConsistencyRate  Float    @default(0)
  avgSessionDuration    Float    @default(0)
  weeklyActiveHours     Float    @default(0)
  interactionDensity    Float    @default(0)
  lastCalculated        DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  student User @relation(fields: [studentId], references: [id])
}

model StudentProgress {
  id           String   @id @default(cuid())
  studentId    String   @unique
  xp           Int      @default(0)
  level        Int      @default(1)
  previousRank Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student User @relation(fields: [studentId], references: [id])
}

model WellbeingCheckin {
  id          String   @id @default(cuid())
  studentId   String
  checkinType String   @default("motivational") // motivational, break_reminder, balance_tip
  title       String
  content     String
  isDismissed Boolean  @default(false)
  createdAt   DateTime @default(now())

  student User @relation(fields: [studentId], references: [id])
}

model InterventionRecord {
  id          String   @id @default(cuid())
  teacherId   String
  studentId   String
  courseId    String?
  reason      String
  status      String   @default("draft") // draft, sent, acknowledged
  message     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PomodoroSession {
  id             String     @id @default(cuid())
  studentId      String
  type           String     // focus, shortBreak, longBreak
  duration       Int        // planned duration in minutes
  actualSeconds  Int        @default(0) // actual seconds completed
  startedAt      DateTime
  completedAt    DateTime
  createdAt      DateTime   @default(now())

  @@index([studentId, completedAt])
}

model PomodoroSettings {
  id                  String   @id @default(cuid())
  studentId           String   @unique
  focusDuration       Int      @default(25)
  shortBreakDuration  Int      @default(5)
  longBreakDuration   Int      @default(15)
  autoStart           Boolean  @default(false)
  soundEnabled        Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}

enum MistakeType {
  CONCEPT_MISUNDERSTANDING
  FALSE_ASSUMPTION
  FORMULA_MISUSE
  ALGEBRAIC_ERROR
  CALCULATION_FLOW_EXCEPTION
  LOGIC_ERROR
  SEQUENTIAL_REASONING_FAILURE
  SYNTAX_ERROR
  EXECUTION_FLOW_DISCONNECT
  MISINTERPRETATION
  CARELESS_MISTAKE
  KNOWLEDGE_GAP
  GUESS_BASED
  SUPERFICIALLY_MEMORIZED
}

enum CorrectnessLevel {
  CORRECT
  PARTIALLY_CORRECT
  INCORRECT
  CONCEPTUALLY_INCOMPLETE
  GUESS_BASED
  SUPERFICIALLY_MEMORIZED
}

enum RecoveryStatus {
  NOT_STARTED
  IN_PROGRESS
  PRACTICING
  MASTERED
  REVIEWING
}

model MisconceptionLog {
  id                 String         @id @default(cuid())
  studentId          String
  conceptNodeId      String
  frequencyCounter   Int            @default(1)
  lastTriggeredAt    DateTime       @default(now())
  recoveryStatus     RecoveryStatus @default(NOT_STARTED)
  mistakeType        MistakeType
  patternDescription String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, conceptNodeId])
  @@index([studentId])
  @@index([studentId, frequencyCounter])
}

model CognitiveProfile {
  id                    String   @id @default(cuid())
  studentId             String   @unique
  totalEvaluations      Int      @default(0)
  totalExplanations     Int      @default(0)
  strongestAreas        String?
  weakestAreas          String?
  repeatedPatterns      String?
  recoveryRate          Float    @default(0)
  averageDissonanceScore Float   @default(0)
  lastAnalyzedAt        DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model MistakeExplanation {
  id                String         @id @default(cuid())
  studentId         String
  attemptId         String?
  questionId        String?
  mistakeType       MistakeType
  correctnessLevel  CorrectnessLevel
  mistakeSummary    String
  rootCauseAnalysis String          @default("")
  correctConcept    String          @default("")
  simplifiedAnalogy String          @default("")
  stepByStepCorrection String      @default("")
  preventionTips    String          @default("")
  reasoningBreakdown String         @default("")
  errorCategory     String?
  conceptLabel      String?
  knowledgeGaps     String?
  confidenceDissonanceFlag Boolean @default(false)
  modelUsed         String         @default("cognitive-coach-v1")
  tokenCount        Int?
  latencyMs         Int?
  createdAt         DateTime       @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([studentId, createdAt])
  @@index([studentId, errorCategory])
}

model RemediationExercise {
  id            String   @id @default(cuid())
  studentId     String
  explanationId String?
  conceptNodeId String
  exerciseType  String
  difficulty    String   @default("adaptive")
  question      String
  correctAnswer String
  options       String?
  hint          String?
  studentAnswer String?
  isCompleted   Boolean  @default(false)
  score         Float?
  createdAt     DateTime @default(now())
  completedAt   DateTime?

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, conceptNodeId])
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  type        String   // Document, Video, Link, Note
  subject     String?
  description String?
  authorId    String?
  authorName  String?
  url         String?
  fileSize    String?
  downloads   Int      @default(0)
  rating      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User? @relation(fields: [authorId], references: [id])
}

model Assignment {
  id             String   @id @default(cuid())
  title          String
  description    String?
  courseId       String
  teacherId      String
  taskType       String   // exam, project, assignment, quiz, presentation, lab_report
  assignedDate   DateTime @default(now())
  dueDate        DateTime
  estimatedHours Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher User   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model StudyNote {
  id        String    @id @default(cuid())
  studentId String
  title     String    @default("")
  content   String    @default("")
  category  String    @default("General")
  tags      String    @default("[]")
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([studentId, updatedAt])
}

model FollowUpMessage {
  id         String   @id @default(cuid())
  studentId  String
  attemptId  String?
  questionId String?
  message    String
  response   String?
  source     String   @default("explain-mistake")
  createdAt  DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([studentId, createdAt])
}

model MoodEntry {
  id        String   @id @default(cuid())
  studentId String
  mood      String   // happy, normal, stressed, burned_out, anxious
  note      String?
  score     Int      @default(5) // 1-10
  createdAt DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}

model WellbeingJournal {
  id          String   @id @default(cuid())
  studentId   String
  title       String
  content     String
  emotionTag  String?  // happy, sad, anxious, stressed, grateful, etc
  isPrivate   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}

model MentorMessage {
  id        String   @id @default(cuid())
  studentId String
  role      String   // user, mentor
  content   String
  category  String?  // support, advice, motivation, warning
  createdAt DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}

model FocusSession {
  id            String   @id @default(cuid())
  studentId     String
  type          String   @default("pomodoro") // pomodoro, deep_focus, quick
  duration      Int      @default(25) // planned minutes
  actualSeconds Int      @default(0)
  completed     Boolean  @default(false)
  distractionScore Float? @default(0)
  notes         String?
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, startedAt])
}

model BurnoutPrediction {
  id             String   @id @default(cuid())
  studentId      String
  riskPercentage Float    @default(0)
  riskLevel      String   @default("low") // low, moderate, high, severe
  factors        String?  // JSON array of contributing factors
  recommendations String? // JSON array of recommendations
  analyzedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, analyzedAt])
}

model BurnoutCheckIn {
  id           String   @id @default(cuid())
  studentId    String
  rating       Int      // 1-5 self-reported burnout
  stressRating Int?     // 1-5 self-reported stress (calm → overwhelmed)
  riskScore    Int?     // snapshot of their risk score at check-in time
  riskLevel    String?  // snapshot of their risk level
  fingerprint  String?  // Stores JSON of personalized Fingerprint
  createdAt    DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}

model WellbeingAnalytics {
  id                String   @id @default(cuid())
  studentId         String   @unique
  wellbeingScore    Float    @default(75) // 0-100
  stressScore       Float    @default(30) // 0-100
  productivityScore Float    @default(70) // 0-100
  burnoutRisk       Float    @default(10) // 0-100
  consistencyScore  Float    @default(65) // 0-100
  lastMood          String?  @default("normal")
  studyBalance      Float    @default(50) // 0-100
  updatedAt         DateTime @default(now())
  createdAt         DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model CompanionInteraction {
  id              String   @id @default(cuid())
  studentId       String
  interactionType String   // greeting, encouragement, achievement, streak, reminder
  message         String
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}

model VoiceInteraction {
  id          String   @id @default(cuid())
  studentId   String
  query       String
  response    String
  intent      String?  // productivity_check, burnout_check, subject_focus, etc
  createdAt   DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}

model RevisionPlan {
  id          String   @id @default(cuid())
  studentId   String
  topicId     String?
  topicName   String
  nextReview  DateTime
  interval    Int      @default(1) // days until next review
  difficulty  Float    @default(0.5) // 0-1
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, nextReview])
}

model AcademicRisk {
  id            String   @id @default(cuid())
  studentId     String
  riskType      String   // cgpa_decline, attendance, exam_failure, productivity
  probability   Float    @default(0) // 0-100
  severity      String   @default("low")
  indicator     String?  // What triggered this prediction
  recommendation String?
  analyzedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, riskType, analyzedAt])
}

model SemesterSnapshot {
  id              String   @id @default(cuid())
  studentId       String
  studentName     String
  semester        Int
  cgpa            Float
  quizAverage     Float
  quizCount       Int
  studyHours      Float
  consistencyRate Float
  interactionDensity Float
  completionRate  Float
  weakTopics      String?
  courseCount     Int
  attendanceAvg   Float
  createdAt       DateTime @default(now())

  @@index([studentId])
  @@index([semester])
  @@index([quizAverage])
  @@index([cgpa])
  @@index([consistencyRate])
  @@index([studyHours])
}

model StudyGroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  topic       String?
  maxMembers  Int      @default(5)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members StudyGroupMember[]
}

model StudyGroupMember {
  id        String   @id @default(cuid())
  groupId   String
  studentId String
  role      String   @default("member") // creator, admin, member
  joinedAt  DateTime @default(now())

  group   StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
}

model DeathWeekPlan {
  id          String   @id @default(cuid())
  userId      String
  weekName    String
  startDate   DateTime
  endDate     DateTime
  subjects    String?  // JSON array of tasks
  schedule    String?  // JSON (trigger type)
  goals       String?  // JSON array of goals
  progress    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
